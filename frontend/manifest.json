{
  "manifest_version": 3,
  "name": "LENS",
  "version": "1.0",
  "description": "Fact-Checker for vernacular news",
  "icons": {
  "16": "icons/icon16.png",
  "48": "icons/icon48.png",
  "128": "icons/icon128.png"
},
  "permissions": [
    "sidePanel",
    "scripting",
    "activeTab",
    "tabs",
    "storage"
  ],
  "host_permissions": [
  "http://127.0.0.1:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}


